---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import BrandLogo from '../components/ui/BrandLogo.astro';
import {
  CONTACT,
  SITE_URL,
  SITE_NAME,
  DEFAULT_OG_IMAGE,
} from '../utils/constants';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
const pageUrl = `${SITE_URL}/orcamento`;

const dadosParaPedido = [
  'Tipo de serviço (residencial, corporativo ou frete)',
  'Origem e destino (bairro e cidade já ajudam)',
  'Data ou janela desejada',
  'Itens grandes ou especiais (geladeira, piano, servidor…)',
];
---

<BaseLayout
  title={`Solicitar orçamento | ${SITE_NAME}`}
  description="Peça orçamento gratuito para mudança, frete ou logística. A Granbel responde com proposta clara e prazo estimado."
  keywords="orçamento mudança, orçamento frete, pedido de orçamento transporte"
  canonical={pageUrl}
  image={DEFAULT_OG_IMAGE}
  url={pageUrl}
  loadTurnstile={!!TURNSTILE_SITE_KEY}
>
  <div class="pt-24 md:pt-28 pb-16 md:pb-20 bg-cardboard min-h-[calc(100vh-6rem)]">
    <div class="container mx-auto px-6 max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-5 order-2 lg:order-1 lg:sticky lg:top-28">
          <a href="/" class="inline-flex items-center gap-3 mb-8 group" aria-label={`${SITE_NAME} — voltar ao início`}>
            <BrandLogo theme="onLight" />
            <span class="text-xs font-sans text-[var(--color-platinum)]/50 group-hover:text-[var(--color-cyan)] transition-colors shrink-0">← Início</span>
          </a>

          <div class="flex gap-2 mb-6" aria-hidden="true">
            {[1, 2, 3].map((n) => (
              <span class="flex items-center justify-center w-8 h-8 rounded-full border-2 border-[var(--color-yellow)] text-xs font-mono font-bold text-[var(--color-yellow)]">
                {n}
              </span>
            ))}
            <span class="flex-1 border-t-2 border-dashed border-[var(--color-cyan)]/35 self-center ml-2 min-w-[3rem]"></span>
          </div>

          <h1 class="font-serif text-3xl md:text-4xl font-bold text-[var(--color-platinum)] leading-tight mb-4">
            Orçamento sem compromisso
          </h1>
          <p class="font-sans text-[var(--color-platinum)]/75 mb-8 leading-relaxed">
            Quanto mais contexto você mandar, menos idas e vindas — e mais preciso fica o valor.
          </p>

          <div class="rounded-xl border border-[var(--color-platinum)]/15 bg-[var(--color-background)]/70 p-6 mb-8">
            <p class="font-sans text-xs font-bold uppercase tracking-widest text-[var(--color-cyan)] mb-4">Inclua no pedido</p>
            <ol class="space-y-3 font-sans text-sm text-[var(--color-platinum)]/85 list-decimal pl-4 marker:text-[var(--color-yellow)]">
              {dadosParaPedido.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </div>

          <p class="font-sans text-sm text-[var(--color-platinum)]/55">
            Dúvida na hora de preencher?{' '}
            <a href={`https://wa.me/${CONTACT.whatsapp}`} class="text-[var(--color-cyan)] font-medium hover:underline">
              Chame no WhatsApp
            </a>
          </p>
        </div>

        <div class="lg:col-span-7 order-1 lg:order-2">
          <div class="rounded-2xl border-2 border-dashed border-[var(--color-cyan)]/35 bg-[var(--color-background-dark)]/95 p-6 md:p-8 lg:p-10 shadow-2xl shadow-black/20">
            <p class="font-mono text-[10px] text-[var(--color-platinum)]/40 uppercase tracking-widest mb-2">Pedido de orçamento</p>
            <form id="contact-form" class="space-y-5" novalidate>
              <div class="absolute -left-[9999px] w-px h-px overflow-hidden opacity-0" aria-hidden="true">
                <input type="text" name="company_website" autocomplete="off" tabindex="-1" />
              </div>

              <div>
                <label for="name" class="block text-[var(--color-platinum)] mb-2 font-medium font-sans">
                  Nome completo <span class="text-red-400">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 bg-[var(--color-background)] border border-[var(--color-platinum)]/25 rounded-lg text-[var(--color-platinum)] placeholder:text-[var(--color-platinum)]/45 focus:outline-none focus:ring-2 focus:ring-[var(--color-cyan)] focus:border-transparent font-sans"
                  placeholder="Seu nome"
                />
              </div>

              <div>
                <label for="phone" class="block text-[var(--color-platinum)] mb-2 font-medium font-sans">
                  Telefone / WhatsApp <span class="text-red-400">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 bg-[var(--color-background)] border border-[var(--color-platinum)]/25 rounded-lg text-[var(--color-platinum)] placeholder:text-[var(--color-platinum)]/45 focus:outline-none focus:ring-2 focus:ring-[var(--color-cyan)] focus:border-transparent font-sans"
                  placeholder="(11) 99999-9999"
                />
              </div>

              <div>
                <label for="email" class="block text-[var(--color-platinum)] mb-2 font-medium font-sans">
                  E-mail <span class="text-red-400">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 bg-[var(--color-background)] border border-[var(--color-platinum)]/25 rounded-lg text-[var(--color-platinum)] placeholder:text-[var(--color-platinum)]/45 focus:outline-none focus:ring-2 focus:ring-[var(--color-cyan)] focus:border-transparent font-sans"
                  placeholder="voce@email.com"
                />
              </div>

              <div>
                <label for="address" class="block text-[var(--color-platinum)] mb-2 font-medium font-sans">
                  Endereço (opcional)
                </label>
                <input
                  type="text"
                  id="address"
                  name="address"
                  class="w-full px-4 py-3 bg-[var(--color-background)] border border-[var(--color-platinum)]/25 rounded-lg text-[var(--color-platinum)] placeholder:text-[var(--color-platinum)]/45 focus:outline-none focus:ring-2 focus:ring-[var(--color-cyan)] focus:border-transparent font-sans"
                  placeholder="Rua, cidade, CEP"
                />
              </div>

              <div>
                <label for="message" class="block text-[var(--color-platinum)] mb-2 font-medium font-sans">
                  Detalhes do serviço <span class="text-red-400">*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  class="w-full px-4 py-3 bg-[var(--color-background)] border border-[var(--color-platinum)]/25 rounded-lg text-[var(--color-platinum)] placeholder:text-[var(--color-platinum)]/45 focus:outline-none focus:ring-2 focus:ring-[var(--color-cyan)] focus:border-transparent resize-none font-sans"
                  placeholder="Tipo de mudança ou frete, tamanho do imóvel, andar, necessidade de embalagem, data preferida…"
                ></textarea>
              </div>

              {TURNSTILE_SITE_KEY && (
                <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} id="turnstile-orcamento"></div>
              )}

              <div id="form-message" class="hidden p-4 rounded-lg text-base font-medium font-sans"></div>

              <Button variant="primary" size="lg" class="w-full" type="submit">
                Enviar solicitação
              </Button>

              <p class="text-center text-sm text-[var(--color-platinum)]/65 font-sans">
                Resposta em horário comercial ·{' '}
                <a href="/contato" class="text-[var(--color-cyan)] hover:underline font-medium">
                  Formulário de contato
                </a>
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import emailjs from '@emailjs/browser';
  import { CONTACT } from '../utils/constants';

  const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID || '';
  const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID || '';
  const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY || '';
  const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

  if (EMAILJS_PUBLIC_KEY) {
    emailjs.init(EMAILJS_PUBLIC_KEY);
  }

  const formatPhoneBR = (value: string): string => {
    const digits = value.replace(/\D/g, '').slice(0, 11);
    if (digits.length === 0) return '';
    if (digits.length <= 2) return `(${digits}`;
    if (digits.length <= 6) return `(${digits.slice(0, 2)}) ${digits.slice(2)}`;
    if (digits.length <= 10) return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
    return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
  };

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    if (!form) return;

    const phoneInput = form.querySelector('#phone') as HTMLInputElement | null;
    const emailInput = form.querySelector('#email') as HTMLInputElement | null;

    if (phoneInput) {
      phoneInput.addEventListener('input', (event) => {
        const target = event.target as HTMLInputElement;
        target.value = formatPhoneBR(target.value);
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const messageDiv = document.getElementById('form-message');
      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

      const formData = new FormData(form as HTMLFormElement);

      const templateParams = {
        from_name: formData.get('name'),
        from_phone: formData.get('phone'),
        from_email: formData.get('email'),
        from_address: formData.get('address') || '',
        message: formData.get('message'),
        to_email: CONTACT.email,
      };

      if (formData.get('company_website')) return;

      const email = String(formData.get('email') || '').trim();
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailPattern.test(email)) {
        if (messageDiv) {
          messageDiv.className =
            'p-4 rounded-lg bg-red-100 border-2 border-red-700 text-red-900 text-base font-medium';
          messageDiv.textContent = 'Informe um e-mail válido.';
          messageDiv.classList.remove('hidden');
        }
        if (emailInput) emailInput.focus();
        return;
      }

      if (!EMAILJS_SERVICE_ID || !EMAILJS_TEMPLATE_ID || !EMAILJS_PUBLIC_KEY) {
        if (messageDiv) {
          messageDiv.className = 'p-4 rounded-lg bg-amber-100 border-2 border-amber-600 text-amber-900 text-base font-medium';
          messageDiv.innerHTML = `Formulário ainda não configurado. Use o <a href="https://wa.me/${CONTACT.whatsapp}" target="_blank" rel="noopener" class="underline font-medium">WhatsApp</a> ou <a href="mailto:${CONTACT.email}" class="underline">${CONTACT.email}</a>`;
          messageDiv.classList.remove('hidden');
        }
        return;
      }

      if (TURNSTILE_SITE_KEY) {
        const turnstileResponse = (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | HTMLTextAreaElement)?.value;
        if (!turnstileResponse || !turnstileResponse.trim()) {
          if (messageDiv) {
            messageDiv.className = 'p-4 rounded-lg bg-amber-100 border-2 border-amber-600 text-amber-900 text-base font-medium';
            messageDiv.textContent = 'Complete a verificação antes de enviar.';
            messageDiv.classList.remove('hidden');
          }
          return;
        }
      }

      if (submitButton) {
        submitButton.disabled = true;
        (submitButton as HTMLButtonElement).innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Enviando...';
      }
      if (messageDiv) messageDiv.classList.add('hidden');

      try {
        await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams);

        if (messageDiv) {
          messageDiv.className = 'p-4 rounded-lg bg-green-100 border-2 border-green-700 text-green-900 text-base font-medium';
          messageDiv.innerHTML = '<i class="fas fa-check-circle mr-2"></i>Recebemos sua solicitação. Retornaremos em breve.';
          messageDiv.classList.remove('hidden');
        }
        (form as HTMLFormElement).reset();

        if (TURNSTILE_SITE_KEY && typeof window !== 'undefined' && (window as any).turnstile) {
          try {
            (window as any).turnstile.reset();
          } catch (_) {}
        }
      } catch (err) {
        console.error('EmailJS error:', err);
        if (messageDiv) {
          messageDiv.className = 'p-4 rounded-lg bg-red-100 border-2 border-red-700 text-red-900 text-base font-medium';
          messageDiv.innerHTML = `<i class="fas fa-exclamation-circle mr-2"></i>Algo deu errado. Tente o <a href="https://wa.me/${CONTACT.whatsapp}" target="_blank" rel="noopener" class="underline font-medium">WhatsApp</a>.`;
          messageDiv.classList.remove('hidden');
        }
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          (submitButton as HTMLButtonElement).innerHTML = 'Enviar solicitação';
        }
      }
    });
  });
</script>

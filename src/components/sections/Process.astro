---
import { PROCESS_STEPS, CONTACT } from '../../utils/constants';
---

<section id="process" class="relative py-20 md:py-24 bg-[var(--color-background-dark)]">
  <div class="container relative z-10 mx-auto px-6">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-[var(--color-platinum)] font-serif">
      Como funciona
    </h2>
    <p class="text-center text-[var(--color-platinum)]/70 mb-14 md:mb-16 text-lg max-w-2xl mx-auto font-sans">
      Transparência do primeiro contato à entrega — sem surpresas.
    </p>
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {PROCESS_STEPS.map((step) => (
          <div class="process-step relative bg-[var(--color-background)] rounded-xl p-6 md:p-8 border border-[var(--color-platinum)]/20 hover:border-[var(--color-cyan)]/45 transition-all duration-300">
            <div class="absolute -top-3 -left-3 w-12 h-12 rounded-lg bg-[var(--color-yellow)] flex items-center justify-center text-[var(--color-dark-blue)] font-bold text-lg shadow-lg font-sans">
              {step.number}
            </div>
            <h3 class="text-xl font-semibold mb-3 mt-2 text-[var(--color-platinum)] font-serif">
              {step.title}
            </h3>
            <p class="text-[var(--color-platinum)]/70 leading-relaxed font-sans">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>
    <p class="mt-12 text-center text-[var(--color-platinum)]/80 font-sans">
      Dúvidas? Chame no{' '}
      <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener noreferrer" class="text-[var(--color-cyan)] hover:underline font-medium">
        WhatsApp
      </a>{' '}
      ou{' '}
      <a href="/orcamento" class="text-[var(--color-cyan)] hover:underline font-medium">
        peça um orçamento
      </a>
      .
    </p>
  </div>
</section>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import {
  ABOUT_HIGHLIGHTS,
  SITE_URL,
  SITE_NAME,
  DEFAULT_OG_IMAGE,
  PLACEHOLDER_IMAGES,
} from '../utils/constants';

const pageUrl = `${SITE_URL}/sobre-nos`;
---

<BaseLayout
  title={`About | ${SITE_NAME}`}
  description="Template about page — replace story, highlights, and imagery. Data for the grid lives in `ABOUT_HIGHLIGHTS` inside `src/utils/constants.ts`."
  keywords="about, team, YOUR_SITE_NAME"
  canonical={pageUrl}
  image={DEFAULT_OG_IMAGE}
  url={pageUrl}
>
  <section
    class="relative pt-24 pb-16 md:pt-28 md:pb-20 min-h-[640px] md:min-h-[720px] flex items-center bg-cover bg-no-repeat bg-center"
    style={`background-image: url('${PLACEHOLDER_IMAGES.heroSlide}');`}
  >
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-dark-blue)]/96 via-[var(--color-dark-blue)]/85 to-[var(--color-dark-blue)]/50" aria-hidden="true"></div>
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[18%] w-7 h-7 bg-[var(--color-yellow)] opacity-50 rotate-12"></div>
      <div class="absolute left-[1.5%] bottom-[22%] w-6 h-10 bg-[var(--color-cyan)] opacity-45 -rotate-6"></div>
      <div class="absolute right-[2%] top-[28%] w-6 h-6 bg-[var(--color-cyan)] opacity-50 -rotate-12"></div>
      <div class="absolute right-[1.5%] bottom-[18%] w-8 h-6 bg-[var(--color-yellow)] opacity-55 rotate-6"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6">
      <div class="max-w-2xl hero-text-contrast">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-white">
          Every project is scoped individually.
        </h1>
        <p class="text-lg md:text-xl text-[var(--color-cyan)] font-medium mb-5 text-drop-shadow">
          Lead with your mission or differentiator in one sentence.
        </p>
        <p class="text-white/95 text-base md:text-lg leading-relaxed mb-5 text-drop-shadow">
          Use this section for company history, methodology, or leadership philosophy. Swap the background image in `PLACEHOLDER_IMAGES` or add files under `public/assets/`.
        </p>
        <p class="text-white/90 text-base md:text-lg text-drop-shadow">
          Keep paragraphs short — detailed proof belongs in the highlight grid below.
        </p>
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-24 bg-[var(--color-background)]">
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
      <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
      <div class="absolute right-[2%] top-[15%] w-8 h-8 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
      <div class="absolute right-[1.5%] bottom-[30%] w-6 h-8 bg-[var(--color-yellow)] opacity-62 rotate-12"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-center mb-4 text-[var(--color-platinum)]">
        Highlights
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto mt-12">
        {ABOUT_HIGHLIGHTS.map((d) => (
          <div class="flex items-start gap-4 p-5 rounded-lg bg-[var(--color-background-dark)] border border-[var(--color-platinum)]/20 hover:border-[var(--color-cyan)]/40 transition-all">
            <div class="flex-shrink-0 w-12 h-12 rounded-sm bg-[var(--color-yellow)] flex items-center justify-center">
              <i class={`fas ${d.icon} text-lg text-[var(--color-dark-blue)]`}></i>
            </div>
            <p class="text-[var(--color-platinum)]/90 font-medium pt-1">
              {d.title}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-24 bg-gradient-to-br from-[var(--color-dark-blue)]/20 via-[var(--color-background)] to-[var(--color-cyan)]/15">
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
      <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
      <div class="absolute right-[2%] top-[18%] w-8 h-6 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
      <div class="absolute right-[1.5%] bottom-[28%] w-6 h-7 bg-[var(--color-yellow)] opacity-62 rotate-10"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <blockquote class="text-2xl md:text-3xl lg:text-4xl font-semibold text-[var(--color-platinum)] mb-8 leading-snug">
          &ldquo;One memorable quote from leadership or a client — replace in `sobre-nos.astro`.&rdquo;
        </blockquote>
        <div class="flex flex-col items-center gap-4">
          <img
            src={PLACEHOLDER_IMAGES.portrait}
            alt="Team member placeholder"
            class="w-24 h-24 md:w-28 md:h-28 rounded-full object-cover border-4 border-[var(--color-cyan)] shadow-lg"
            width="112"
            height="112"
          />
          <cite class="text-[var(--color-cyan)] font-medium text-lg not-italic">
            Name, Role
          </cite>
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-24 bg-gradient-to-br from-[var(--color-dark-blue)]/15 via-[var(--color-background)] to-[var(--color-cyan)]/15">
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
      <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
      <div class="absolute right-[2%] top-[18%] w-8 h-6 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
      <div class="absolute right-[1.5%] bottom-[28%] w-6 h-7 bg-[var(--color-yellow)] opacity-62 rotate-10"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-[var(--color-platinum)]">
        Request a quote
      </h2>
      <p class="text-lg md:text-xl text-[var(--color-platinum)]/85 mb-10 max-w-2xl mx-auto">
        Close with a simple next step — same CTA pattern as other inner pages.
      </p>
      <Button href="/orcamento" variant="primary" size="lg">
        Get started
      </Button>
    </div>
  </section>
</BaseLayout>

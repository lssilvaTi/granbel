---
import { COVERAGE_CITIES } from '../../utils/constants';
---

<section id="onde-atendemos" class="relative py-14 md:py-16 bg-[var(--color-background)] border-y border-[var(--color-platinum)]/10">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 max-w-5xl mx-auto">
      <div class="shrink-0">
        <p class="font-sans text-xs font-bold tracking-[0.25em] text-[var(--color-cyan)] uppercase mb-2">Rotas &amp; base</p>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-[var(--color-platinum)] max-w-xs">
          Para onde levamos sua carga
        </h2>
      </div>

      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center gap-x-0 gap-y-3 font-sans text-sm md:text-base text-[var(--color-platinum)]/85">
          {COVERAGE_CITIES.map((city, i) => (
            <span class="inline-flex items-center">
              {i > 0 && (
                <span class="text-[var(--color-cyan)]/45 px-2 select-none" aria-hidden="true">
                  <i class="fas fa-chevron-right text-[10px]"></i>
                </span>
              )}
              <span
                class:list={[
                  'inline-flex items-center gap-1.5 rounded-full border border-[var(--color-platinum)]/15 bg-[var(--color-background-dark)]/80 px-3 py-1.5 text-left leading-snug',
                  city.length > 28 ? 'max-w-[min(100%,19rem)] whitespace-normal' : 'whitespace-nowrap',
                ]}
              >
                <i class="fas fa-location-dot text-[var(--color-yellow)] text-xs" aria-hidden="true"></i>
                {city}
              </span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

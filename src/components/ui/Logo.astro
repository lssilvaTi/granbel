---
import { LOGO_PATH, SITE_NAME } from '../../utils/constants';

interface Props {
  variant?: 'full' | 'full-dark' | 'full-light' | 'wordmark-dark' | 'wordmark-light' | 'mono-dark' | 'mono-light';
  class?: string;
}

/**
 * All variants map to the same placeholder asset in the template.
 * Split into multiple files per client if you need theme-specific marks.
 */
const { variant: _variant = 'full', class: className = '' } = Astro.props;
---

<img 
  src={LOGO_PATH} 
  alt={SITE_NAME} 
  class={`h-8 ${className}`}
/>

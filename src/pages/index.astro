---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import PackagingTapeMarquee from '../components/sections/PackagingTapeMarquee.astro';
import ServicesBento from '../components/sections/ServicesBento.astro';
import WhyGranbelStudio from '../components/sections/WhyGranbelStudio.astro';
import JourneyRoute from '../components/sections/JourneyRoute.astro';
import MovingDayPostits from '../components/sections/MovingDayPostits.astro';
import CoverageThread from '../components/sections/CoverageThread.astro';
import FAQLabels from '../components/sections/FAQLabels.astro';
import CTA from '../components/sections/CTA.astro';
import { SITE_URL, SITE_NAME, DEFAULT_OG_IMAGE, SITE_TAGLINE } from '../utils/constants';
---

<BaseLayout
  title={`${SITE_NAME} | Mudanças e transportes com segurança`}
  description={SITE_TAGLINE}
  keywords="mudanças São Paulo, transporte de mudança, mudança residencial, mudança corporativa, fretes, Granbel, transportadora"
  canonical={SITE_URL}
  image={DEFAULT_OG_IMAGE}
  url={SITE_URL}
>
  <Hero />
  <PackagingTapeMarquee />
  <ServicesBento />
  <WhyGranbelStudio />
  <JourneyRoute />
  <MovingDayPostits />
  <CoverageThread />
  <FAQLabels />
  <CTA />
</BaseLayout>

---
import BrandLogo from './BrandLogo.astro';

interface Props {
  variant?: 'full' | 'full-dark' | 'full-light' | 'wordmark-dark' | 'wordmark-light' | 'mono-dark' | 'mono-light';
  class?: string;
}

const { variant = 'full', class: className = '' } = Astro.props;
const theme =
  variant.endsWith('-light') || variant === 'full-light' ? 'onLight' : 'onDark';
---

<BrandLogo theme={theme} class={className} />

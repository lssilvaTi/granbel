---
import { DIFFERENTIALS, SITE_NAME, VALUE_PROPOSITION_COPY } from '../../utils/constants';
import Button from '../ui/Button.astro';
---

<section id="sobre" class="relative py-12 md:py-20 lg:py-24 bg-[var(--color-background)]">
  <div class="container relative z-10 mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-10 md:mb-20">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-[var(--color-platinum)] font-serif">
        Por que escolher a {SITE_NAME}
      </h2>
      <p class="text-xl md:text-2xl text-[var(--color-cyan)] font-medium mb-8 font-sans">
        {VALUE_PROPOSITION_COPY.kicker}
      </p>
      <p class="text-[var(--color-platinum)]/85 text-lg md:text-xl leading-relaxed mb-6 font-sans">
        {VALUE_PROPOSITION_COPY.lead}
      </p>
      <p class="text-[var(--color-platinum)]/80 text-base md:text-lg leading-relaxed mb-4 font-sans">
        {VALUE_PROPOSITION_COPY.p1}
      </p>
      <p class="text-[var(--color-platinum)]/75 mb-10 font-sans">
        {VALUE_PROPOSITION_COPY.p2}
      </p>
      <Button href="#diferenciais" variant="outline" size="lg">
        {VALUE_PROPOSITION_COPY.cta}
      </Button>
    </div>

    <div id="diferenciais">
      <h3 class="text-2xl md:text-3xl font-bold text-center mb-12 text-[var(--color-platinum)] font-serif">
        Diferenciais que fazem diferença no dia a dia
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {DIFFERENTIALS.map((d) => (
          <div class="flex items-start gap-4 p-5 rounded-xl bg-[var(--color-background-dark)] border border-[var(--color-platinum)]/20 hover:border-[var(--color-cyan)]/45 transition-all duration-300">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-[var(--color-yellow)] flex items-center justify-center">
              <i class={`fas ${d.icon} text-lg text-[var(--color-dark-blue)]`}></i>
            </div>
            <p class="text-[var(--color-platinum)]/90 font-medium pt-1 font-sans text-left">
              {d.title}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
import FAQSchema from '../seo/FAQSchema.astro';
import { FAQ_ITEMS } from '../../utils/constants';
---

<FAQSchema questions={FAQ_ITEMS} />

<section id="faq" class="relative py-20 md:py-24 bg-[var(--color-background-dark)]">
  <div class="container relative z-10 mx-auto px-6 max-w-3xl">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-14 md:mb-16 text-[var(--color-platinum)] font-serif">
      Perguntas frequentes
    </h2>
    <div class="space-y-4">
      {FAQ_ITEMS.map((item) => (
        <details class="faq-item bg-[var(--color-background)] rounded-xl border border-[var(--color-platinum)]/10 group open:shadow-lg open:shadow-black/10 transition-shadow duration-300">
          <summary class="p-5 md:p-6 cursor-pointer list-none flex items-center justify-between text-[var(--color-platinum)] font-semibold hover:text-[var(--color-cyan)] transition-colors gap-4 font-sans">
            <span>{item.question}</span>
            <i class="fas fa-chevron-down text-sm flex-shrink-0 transition-transform duration-300 group-open:rotate-180"></i>
          </summary>
          <div class="px-5 md:px-6 pb-5 md:pb-6 text-[var(--color-platinum)]/75 leading-relaxed font-sans">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

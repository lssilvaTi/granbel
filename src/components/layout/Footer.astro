---
import BrandLogo from '../ui/BrandLogo.astro';
import { CONTACT, SITE_NAME, SITE_TAGLINE } from '../../utils/constants';
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-header-bg)] border-t border-white/10 py-12 md:py-16">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex mb-4 hover:opacity-90 transition-opacity" aria-label={SITE_NAME}>
          <BrandLogo theme="onDark" />
        </a>
        <p class="text-white/75 max-w-md leading-relaxed font-sans">
          {SITE_TAGLINE}
        </p>
        <div class="flex flex-wrap gap-3 mt-6">
          <a
            href={CONTACT.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[var(--color-yellow)] hover:text-[var(--color-ink-black)] transition-colors"
            aria-label="Facebook"
          >
            <i class="fab fa-facebook-f"></i>
          </a>
          <a
            href={CONTACT.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[var(--color-yellow)] hover:text-[var(--color-ink-black)] transition-colors"
            aria-label="Instagram"
          >
            <i class="fab fa-instagram"></i>
          </a>
          <a
            href={CONTACT.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[var(--color-yellow)] hover:text-[var(--color-ink-black)] transition-colors"
            aria-label="LinkedIn"
          >
            <i class="fab fa-linkedin-in"></i>
          </a>
          <a
            href={`https://wa.me/${CONTACT.whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[#25D366] transition-colors"
            aria-label="WhatsApp"
          >
            <i class="fab fa-whatsapp"></i>
          </a>
        </div>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4 font-serif">Páginas</h3>
        <ul class="space-y-2 font-sans">
          <li><a href="/" class="text-white/75 hover:text-[var(--color-yellow)] transition-colors">Início</a></li>
          <li><a href="/sobre-nos" class="text-white/75 hover:text-[var(--color-yellow)] transition-colors">Sobre nós</a></li>
          <li><a href="/servicos" class="text-white/75 hover:text-[var(--color-yellow)] transition-colors">Serviços</a></li>
          <li><a href="/contato" class="text-white/75 hover:text-[var(--color-yellow)] transition-colors">Contato</a></li>
          <li><a href="/orcamento" class="text-white/75 hover:text-[var(--color-yellow)] transition-colors">Orçamento</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4 font-serif">Fale conosco</h3>
        <ul class="space-y-3 text-white/75 font-sans text-sm">
          <li>{CONTACT.address}</li>
          <li>{CONTACT.addressLine2}</li>
          <li>CEP {CONTACT.postalCode}</li>
          <li>
            <a href={`mailto:${CONTACT.email}`} class="hover:text-[var(--color-yellow)] transition-colors">{CONTACT.email}</a>
          </li>
          <li>
            <a href={`tel:${CONTACT.phoneTel}`} class="hover:text-[var(--color-yellow)] transition-colors">{CONTACT.phoneDisplay}</a>
          </li>
          <li>
            <a
              href={`https://wa.me/${CONTACT.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[#25D366] transition-colors inline-flex items-center gap-2"
            >
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-10 pt-8 border-t border-white/10 text-center text-white/50 text-sm font-sans">
      <p>© {currentYear} {SITE_NAME}. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

# EmailJS — contact + quote forms (`contato.astro`, `orcamento.astro`)
# Keys: https://www.emailjs.com/
#
# Template variables expected by this project:
#   {{from_name}} {{from_phone}} {{from_email}} {{from_address}} {{message}} {{to_email}}
#
# Set the template “To” field to your inbox, or use {{to_email}} filled from `CONTACT.email` in code.

PUBLIC_EMAILJS_SERVICE_ID=your_service_id
PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Cloudflare Turnstile (optional)
# https://developers.cloudflare.com/turnstile/
# If unset, honeypot-only anti-spam still applies.

PUBLIC_TURNSTILE_SITE_KEY=

---
import { SERVICES } from '../../utils/constants';
---

<section id="services" class="relative py-12 md:py-20 lg:py-24 bg-[var(--color-background)]">
  <div class="container relative z-10 mx-auto px-6">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-[var(--color-dark-blue)] font-serif">
      O que fazemos por você
    </h2>
    <p class="text-center text-[var(--color-cyan)] mb-10 md:mb-16 text-lg md:text-xl max-w-2xl mx-auto font-medium font-sans">
      Soluções sob medida — da opção mais enxuta ao serviço completo com equipe dedicada.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8 lg:gap-10 max-w-5xl mx-auto">
      {SERVICES.map((service) => (
        <div class="service-card flex flex-col items-center text-center p-6 md:p-8 bg-[var(--color-background-dark)] rounded-xl border border-[var(--color-platinum)]/20 hover:border-[var(--color-cyan)]/45 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-black/15">
          <div class="w-16 h-16 mb-4 md:mb-6 rounded-lg bg-[var(--color-yellow)] flex items-center justify-center flex-shrink-0">
            <i class={`fas ${service.icon} text-2xl text-[var(--color-dark-blue)]`}></i>
          </div>
          <h3 class="text-xl md:text-2xl font-semibold mb-3 md:mb-4 text-[var(--color-cyan)] font-serif">
            {service.title}
          </h3>
          <p class="text-[var(--color-platinum)]/80 leading-relaxed max-w-md font-sans">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

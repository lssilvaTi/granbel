---
import { CONTACT, LOGO_PATH, SITE_NAME, SITE_TAGLINE } from '../../utils/constants';
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-header-bg)] border-t border-white/10 py-12 md:py-16">
  <div class="container mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-10">
      <div class="lg:col-span-2">
        <a href="/" class="inline-block mb-4 hover:opacity-90 transition-opacity">
          <img src={LOGO_PATH} alt={SITE_NAME} class="h-10 md:h-12 w-auto" width="180" height="48" />
        </a>
        <p class="text-white/75 max-w-md leading-relaxed">
          {SITE_TAGLINE}
        </p>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Pages</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-white/75 hover:text-[var(--color-cyan)] transition-colors">Home</a></li>
          <li><a href="/sobre-nos" class="text-white/75 hover:text-[var(--color-cyan)] transition-colors">About</a></li>
          <li><a href="/servicos" class="text-white/75 hover:text-[var(--color-cyan)] transition-colors">Services</a></li>
          <li><a href="/contato" class="text-white/75 hover:text-[var(--color-cyan)] transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-white font-semibold mb-4">Contact</h3>
        <ul class="space-y-3 text-white/75">
          <li>Address: {CONTACT.address}</li>
          <li>{CONTACT.addressLine2}</li>
          <li>ZIP: {CONTACT.postalCode}</li>
          <li><a href={`mailto:${CONTACT.email}`} class="hover:text-[var(--color-cyan)] transition-colors">{CONTACT.email}</a></li>
          <li><a href={`tel:${CONTACT.phoneTel}`} class="hover:text-[var(--color-cyan)] transition-colors">{CONTACT.phoneDisplay}</a></li>
          <li>
            <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-cyan)] transition-colors inline-flex items-center gap-2">
              <i class="fab fa-whatsapp"></i> WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="mt-10 pt-8 border-t border-white/10 text-center text-white/50 text-sm">
      <p>© {currentYear} {SITE_NAME}. All rights reserved.</p>
    </div>
  </div>
</footer>

---
import { DIFFERENTIALS, SITE_NAME } from '../../utils/constants';
import Button from '../ui/Button.astro';
---

<section id="sobre" class="relative py-12 md:py-20 lg:py-24 bg-[var(--color-background)]">
  <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
    <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
    <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
    <div class="absolute right-[2%] top-[15%] w-8 h-8 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
    <div class="absolute right-[1.5%] bottom-[30%] w-6 h-8 bg-[var(--color-yellow)] opacity-62 rotate-12"></div>
  </div>
  <div class="container relative z-10 mx-auto px-6">
    <div class="max-w-4xl mx-auto text-center mb-10 md:mb-20">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-[var(--color-platinum)]">
        Why teams choose {SITE_NAME}
      </h2>
      <p class="text-xl md:text-2xl text-[var(--color-cyan)] font-medium mb-8">
        A short credibility line — years in market, niche focus, or social proof.
      </p>
      <p class="text-[var(--color-platinum)]/80 text-lg md:text-xl leading-relaxed mb-8">
        Replace this paragraph with your positioning: who you serve, the problem you solve, and what makes your delivery dependable. Keep it in `constants.ts` if you reuse it on other pages.
      </p>
      <p class="text-[var(--color-platinum)]/75 mb-10">
        Every engagement is scoped individually — no one-size-fits-all boilerplate.
      </p>
      <Button href="#diferenciais" variant="outline" size="lg">
        See what sets us apart
      </Button>
    </div>

    <div id="diferenciais">
      <h3 class="text-2xl md:text-3xl font-bold text-center mb-12 text-[var(--color-platinum)]">
        Our differentiators
      </h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {DIFFERENTIALS.map((d) => (
          <div class="flex items-start gap-4 p-5 rounded-lg bg-[var(--color-background-dark)] border border-[var(--color-platinum)]/20 hover:border-[var(--color-cyan)]/40 transition-all">
            <div class="flex-shrink-0 w-12 h-12 rounded-sm bg-[var(--color-yellow)] flex items-center justify-center">
              <i class={`fas ${d.icon} text-lg text-[var(--color-dark-blue)]`}></i>
            </div>
            <p class="text-[var(--color-platinum)]/90 font-medium pt-1">
              {d.title}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

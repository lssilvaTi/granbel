---
import { TESTIMONIALS } from '../../utils/constants';
---

<section id="testimonials" class="relative py-20 md:py-24 bg-[var(--color-background)]">
  <div class="container relative z-10 mx-auto px-6">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-center mb-4 text-[var(--color-platinum)] font-serif">
      Quem confia na Granbel
    </h2>
    <p class="text-center text-[var(--color-platinum)]/65 mb-14 md:mb-16 max-w-xl mx-auto font-sans">
      Depoimentos reais de quem já viveu o processo conosco — nomes podem ser ajustados com autorização do cliente.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {TESTIMONIALS.map((t) => (
        <div class="testimonial bg-[var(--color-background-dark)] rounded-xl p-6 md:p-8 border border-[var(--color-platinum)]/10 hover:border-[var(--color-cyan)]/30 transition-colors duration-300">
          <div class="flex mb-4">
            {[...Array(t.rating)].map(() => (
              <i class="fas fa-star text-[var(--color-yellow)]"></i>
            ))}
          </div>
          <p class="text-[var(--color-platinum)]/85 mb-6 italic leading-relaxed font-sans">
            &quot;{t.text}&quot;
          </p>
          <div class="flex items-center">
            <div class="w-12 h-12 rounded-full bg-[var(--color-dark-blue)] flex items-center justify-center text-white font-semibold mr-4 font-sans">
              {t.name.charAt(0)}
            </div>
            <span class="text-[var(--color-platinum)] font-medium font-sans">{t.name}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import {
  SITE_URL,
  SITE_NAME,
  DEFAULT_OG_IMAGE,
  PLACEHOLDER_IMAGES,
} from '../utils/constants';

const servicos = [
  {
    id: 'primary',
    title: 'Primary offering',
    text: 'Long-form description for your main service. Move this array to `constants.ts` if you want a single source of truth with the homepage cards.',
    image: PLACEHOLDER_IMAGES.portrait,
    imageAlt: 'Service illustration placeholder',
  },
  {
    id: 'secondary',
    title: 'Bundled or follow-on service',
    text: 'Explain deliverables, timeline, and what the client can expect. Replace images under `public/assets/` or point `image` to your CDN.',
    image: PLACEHOLDER_IMAGES.portrait,
    imageAlt: 'Service illustration placeholder',
  },
  {
    id: 'specialty',
    title: 'Specialty or niche',
    text: 'Use this block for a vertical-specific page. Delete rows from `servicos` if the client needs fewer sections.',
    image: PLACEHOLDER_IMAGES.portrait,
    imageAlt: 'Service illustration placeholder',
  },
  {
    id: 'coverage',
    title: 'Coverage and scale',
    text: 'Describe geographic reach, remote vs on-site, SLAs, or compliance — whatever differentiates you at the proposal stage.',
    image: PLACEHOLDER_IMAGES.portrait,
    imageAlt: 'Service illustration placeholder',
  },
];

const pageUrl = `${SITE_URL}/servicos`;
---

<BaseLayout
  title={`Services | ${SITE_NAME}`}
  description="Template services page — replace meta and body copy per client. Images use shared placeholders until you add real assets."
  keywords="services, YOUR_SITE_NAME, template"
  canonical={pageUrl}
  image={DEFAULT_OG_IMAGE}
  url={pageUrl}
>
  <section
    class="relative pt-24 pb-16 md:pt-28 md:pb-20 min-h-[640px] md:min-h-[720px] flex items-center bg-cover bg-no-repeat bg-center"
    style={`background-image: url('${PLACEHOLDER_IMAGES.heroSlide}');`}
  >
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-dark-blue)]/96 via-[var(--color-dark-blue)]/85 to-[var(--color-dark-blue)]/50" aria-hidden="true"></div>
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[18%] w-7 h-7 bg-[var(--color-yellow)] opacity-50 rotate-12"></div>
      <div class="absolute left-[1.5%] bottom-[22%] w-6 h-10 bg-[var(--color-cyan)] opacity-45 -rotate-6"></div>
      <div class="absolute right-[2%] top-[28%] w-6 h-6 bg-[var(--color-cyan)] opacity-50 -rotate-12"></div>
      <div class="absolute right-[1.5%] bottom-[18%] w-8 h-6 bg-[var(--color-yellow)] opacity-55 rotate-6"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6">
      <div class="max-w-2xl hero-text-contrast">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-white text-drop-shadow">
          Our services
        </h1>
        <p class="text-white/95 text-base md:text-lg leading-relaxed mb-8 text-drop-shadow">
          Summarize the catalog in one paragraph, then scroll for detail blocks — or trim this page for a lighter site.
        </p>
        <Button href="/orcamento" variant="secondary" size="lg">
          Request a quote
        </Button>
      </div>
    </div>
  </section>

  {servicos.map((s, i) => {
    const imageLeft = i % 2 === 0;
    return (
      <section class="relative py-12 md:py-20 lg:py-24 bg-[var(--color-background)]">
        <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
          <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
          <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
          <div class="absolute right-[2%] top-[15%] w-8 h-8 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
          <div class="absolute right-[1.5%] bottom-[30%] w-6 h-8 bg-[var(--color-yellow)] opacity-62 rotate-12"></div>
        </div>
        <div class="container relative z-10 mx-auto px-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 md:gap-10 lg:gap-14 items-center max-w-6xl mx-auto">
            <div class={`order-2 ${!imageLeft ? 'lg:order-2' : 'lg:order-none'}`}>
              <h2 class="text-2xl md:text-3xl font-bold mb-4 md:mb-6 text-[var(--color-cyan)]">
                {s.title}
              </h2>
              <p class="text-[var(--color-platinum)]/80 text-base md:text-lg leading-relaxed">
                {s.text}
              </p>
            </div>
            <div class={`relative flex justify-center order-first lg:order-none ${imageLeft ? 'lg:justify-end' : 'lg:justify-start lg:order-1'}`}>
              <img
                src={s.image}
                alt={s.imageAlt}
                class="rounded-lg shadow-xl w-full max-w-md object-cover aspect-[4/3]"
                width="500"
                height="375"
              />
            </div>
          </div>
        </div>
      </section>
    );
  })}

  <section class="relative py-20 md:py-24 bg-gradient-to-br from-[var(--color-dark-blue)]/20 via-[var(--color-background)] to-[var(--color-cyan)]/15">
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
      <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
      <div class="absolute right-[2%] top-[18%] w-8 h-6 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
      <div class="absolute right-[1.5%] bottom-[28%] w-6 h-7 bg-[var(--color-yellow)] opacity-62 rotate-10"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-6 text-[var(--color-platinum)]">
          Trust and coverage
        </h2>
        <p class="text-xl md:text-2xl text-[var(--color-platinum)]/90 font-medium mb-10">
          Optional block for insurance, certifications, or partner logos — replace copy and image for each client.
        </p>
        <div class="partner-logo-wrap inline-block p-2 md:p-3 rounded-xl">
          <img
            src={PLACEHOLDER_IMAGES.partnerLogo}
            alt="Partner or certification placeholder"
            class="inline-block w-32 h-32 md:w-40 md:h-40 object-contain opacity-90"
            width="160"
            height="160"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="relative py-20 md:py-24 bg-gradient-to-br from-[var(--color-dark-blue)]/15 via-[var(--color-background)] to-[var(--color-cyan)]/15">
    <div class="section-shapes absolute inset-0 pointer-events-none hidden md:block z-0" aria-hidden="true">
      <div class="absolute left-[2%] top-[22%] w-6 h-6 bg-[var(--color-yellow)] opacity-60 rotate-6"></div>
      <div class="absolute left-[1.5%] bottom-[25%] w-7 h-9 bg-[var(--color-cyan)] opacity-55 -rotate-3"></div>
      <div class="absolute right-[2%] top-[18%] w-8 h-6 bg-[var(--color-cyan)] opacity-58 -rotate-6"></div>
      <div class="absolute right-[1.5%] bottom-[28%] w-6 h-7 bg-[var(--color-yellow)] opacity-62 rotate-10"></div>
    </div>
    <div class="container relative z-10 mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 text-[var(--color-platinum)]">
        Request a quote
      </h2>
      <p class="text-lg md:text-xl text-[var(--color-platinum)]/85 mb-10 max-w-2xl mx-auto">
        Short CTA — drives to the quote form route (`/orcamento` in this template).
      </p>
      <Button href="/orcamento" variant="primary" size="lg">
        Get started
      </Button>
    </div>
  </section>
</BaseLayout>

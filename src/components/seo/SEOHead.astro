---
import {
  CONTACT,
  SITE_URL,
  SITE_NAME,
  DEFAULT_OG_IMAGE,
  LOGO_PATH,
} from '../../utils/constants';

interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: string;
  keywords?: string;
  author?: string;
  noindex?: boolean;
  canonical?: string;
}

const {
  title,
  description,
  image = DEFAULT_OG_IMAGE,
  url = SITE_URL,
  type = 'website',
  keywords = 'mudanças, transportes, fretes, São Paulo, Granbel, mudança residencial, mudança corporativa',
  author = SITE_NAME,
  noindex = false,
  canonical,
} = Astro.props;

const siteUrl = url;
const pageUrl = canonical || siteUrl + Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : siteUrl + image;
const logoAbsolute = siteUrl + LOGO_PATH;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="author" content={author} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<meta name="language" content="Portuguese" />
<meta name="revisit-after" content="7 days" />

<link rel="canonical" href={pageUrl} />

<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:image:type" content="image/svg+xml" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={SITE_NAME} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="pt_BR" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={pageUrl} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={SITE_NAME} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<link rel="manifest" href="/site.webmanifest" />

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'MovingCompany',
    name: SITE_NAME,
    url: siteUrl,
    logo: logoAbsolute,
    description: description,
    address: {
      '@type': 'PostalAddress',
      streetAddress: CONTACT.address,
      addressLocality: CONTACT.city,
      addressRegion: CONTACT.region,
      postalCode: CONTACT.postalCode,
      addressCountry: 'BR',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: CONTACT.phoneTel,
      email: CONTACT.email,
      contactType: 'customer service',
      availableLanguage: ['Portuguese', 'pt-BR'],
      areaServed: 'BR',
    },
    sameAs: [CONTACT.facebook, CONTACT.instagram, CONTACT.linkedin].filter(Boolean),
  })}
/>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_NAME,
    url: siteUrl,
    description: description,
    inLanguage: 'pt-BR',
  })}
/>
